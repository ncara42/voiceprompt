# ──────────────────────────────────────────────────────────────────────────────
# Python build / cache
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
.env/

# Build artifacts
build/
dist/
*.egg-info/
*.egg
*.spec
pip-wheel-metadata/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
.tox/
.nox/
.uv/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover

# ──────────────────────────────────────────────────────────────────────────────
# Editor / IDE / OS junk
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
.fleet/
*.sublime-workspace
*.swp
*.swo
*.swn
*~
*.bak
*.orig
*.tmp
*.rej

# ──────────────────────────────────────────────────────────────────────────────
# Per-user agent / IDE settings (never commit)
# ──────────────────────────────────────────────────────────────────────────────
.claude/
.cursor/
.aider*
.codeium/
.continue/
.windsurf*
.firecrawl/

# ──────────────────────────────────────────────────────────────────────────────
# Project runtime artifacts
# ──────────────────────────────────────────────────────────────────────────────
*.wav
*.log
.cache/

# Legacy Swift build (the source is kept under legacy/ as reference)
legacy/swift-macos/.build/
legacy/swift-macos/.swiftpm/

# ──────────────────────────────────────────────────────────────────────────────
# Secrets — NEVER commit
# ──────────────────────────────────────────────────────────────────────────────
*.env
.env
.env.*
config.json
secrets.json
credentials.json
*.pem
*.key
*.p12
